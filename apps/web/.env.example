# Browser-safe Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only Supabase access
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Razorpay test-mode configuration. The exact assignment price is USD $5.
# An Indian account needs International Payments enabled for USD orders.
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_A_SEPARATE_WEBHOOK_SECRET
RAZORPAY_AMOUNT_SUBUNITS=500
RAZORPAY_CURRENCY=USD
# Domestic-only alternative: use 50000 and INR; the paywall renders the configured price.

# Must be a 32-byte base64 value. Example generator:
# openssl rand -base64 32
KEY_ENCRYPTION_SECRET=REPLACE_WITH_32_BYTE_BASE64_VALUE
# Increment when rotating; retain old KEY_ENCRYPTION_SECRET_V<n> values for decryption.
KEY_ENCRYPTION_KEY_VERSION=1

# Private FastAPI service connection
AGENT_SERVICE_URL=http://localhost:8000
AGENT_SERVICE_TOKEN=REPLACE_WITH_THE_SAME_LONG_RANDOM_VALUE_AS_THE_AGENT

# Optional operator-owned web-search keys. Tavily is preferred when both are set.
# LLM provider keys are always user-supplied through Settings.
TAVILY_SEARCH_API_KEY=
BRAVE_SEARCH_API_KEY=

# Development simulator is opt-in and is always disabled in production.
ENABLE_DEV_MOCKS=false
NEXT_PUBLIC_ENABLE_DEMO=false
ALLOW_PRIVATE_MODEL_ENDPOINTS=false
