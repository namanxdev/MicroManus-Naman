# Non-provider configuration only. Never place model-provider or web-search keys here.
MICROMANUS_AGENT_ENVIRONMENT=development
MICROMANUS_AGENT_SERVICE_TOKEN=replace-with-a-long-random-internal-token
MICROMANUS_AGENT_ALLOW_INSECURE_DEV_AUTH=false

MICROMANUS_AGENT_CHECKPOINT_BACKEND=sqlite
MICROMANUS_AGENT_CHECKPOINT_DB_PATH=./data/checkpoints.sqlite
MICROMANUS_AGENT_ARTIFACT_DIR=./data/artifacts
# MICROMANUS_AGENT_PRICING_REGISTRY_PATH=./pricing.custom.json

MICROMANUS_AGENT_DEFAULT_MAX_ITERATIONS=6
MICROMANUS_AGENT_MAX_ITERATIONS_CAP=10
MICROMANUS_AGENT_RUN_TIMEOUT_SECONDS=180
MICROMANUS_AGENT_PROVIDER_TIMEOUT_SECONDS=75
MICROMANUS_AGENT_TOOL_TIMEOUT_SECONDS=20
MICROMANUS_AGENT_SSE_HEARTBEAT_SECONDS=10
MICROMANUS_AGENT_MAX_OUTPUT_TOKENS=8192
MICROMANUS_AGENT_MAX_FETCH_BYTES=2000000
MICROMANUS_AGENT_MAX_FETCH_CHARACTERS=24000
MICROMANUS_AGENT_MAX_PDF_PAGES_TO_FETCH=30
MICROMANUS_AGENT_MAX_REPORT_CHARACTERS=100000
MICROMANUS_AGENT_MAX_SOURCES_PER_RUN=40
